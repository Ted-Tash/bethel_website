          %h3.card-title Convenient Location
          %p.opacity-70 Just 3 minutes from Highway 44 and Elm Avenue

      .card.bg-base-200.shadow-lg
        .card-body.items-center.text-center
          .mb-4
            %svg.h-14.w-14.text-primary{ xmlns: "http://www.w3.org/2000/svg", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" }
