.flex.items-center.justify-between.mb-8
  %h1.text-3xl.font-bold YouTube Audio Extractor
  = link_to 'New Extraction', new_admin_audio_extraction_path, class: 'btn btn-primary'

- if @audio_extractions.any?
  .overflow-x-auto
    %table.table.table-zebra.bg-base-100
      %thead
        %tr
          %th URL
          %th Time Range
          %th Status
          %th File
          %th Created
          %th
      %tbody
        - @audio_extractions.each do |extraction|
          %tr
            %td.max-w-xs.truncate
              = link_to extraction.youtube_url, extraction.youtube_url, target: '_blank', class: 'link link-primary'
            %td
              - if extraction.start_time.present? || extraction.end_time.present?
                = [extraction.start_time, extraction.end_time].compact.join(' - ')
              - else
                %span.opacity-50 Full video
            %td
              - case extraction.status
              - when 'pending'
                %span.badge.badge-warning Pending
              - when 'processing'
                %span.badge.badge-info
                  %span.loading.loading-spinner.loading-xs
                  Processing
              - when 'completed'
                %span.badge.badge-success Completed
              - when 'failed'
                %span.badge.badge-error Failed
            %td
              - if extraction.completed? && extraction.audio_file.attached?
                = link_to extraction.display_name, rails_blob_path(extraction.audio_file, disposition: 'attachment'), class: 'link link-primary text-sm'
                %span.text-xs.opacity-50= number_to_human_size(extraction.file_size) if extraction.file_size
            %td.text-sm.opacity-60= time_ago_in_words(extraction.created_at) + ' ago'
            %td
              = button_to 'Delete', admin_audio_extraction_path(extraction), method: :delete, class: 'btn btn-ghost btn-xs', data: { turbo_confirm: 'Delete this extraction?' }
- else
  .text-center.py-16.opacity-60
    %p No extractions yet. Click "New Extraction" to get started.
