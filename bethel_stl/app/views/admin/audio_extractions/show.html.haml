- poll_attrs = @audio_extraction.in_progress? ? { controller: 'poll', poll_interval_value: 5000 } : {}

.max-w-2xl.mx-auto{ data: poll_attrs }
  = link_to '← Back to Extractions', admin_audio_extractions_path, class: 'btn btn-ghost btn-sm mb-4'

  .card.bg-base-100.shadow-md{ data: { poll_target: 'content' } }
    .card-body
      .flex.items-center.justify-between.mb-6
        %h2.card-title= @audio_extraction.display_name
        - case @audio_extraction.status
        - when 'pending'
          %span.badge.badge-warning.badge-lg Pending
        - when 'processing'
          %span.badge.badge-info.badge-lg
            %span.loading.loading-spinner.loading-xs
            Processing...
        - when 'completed'
          %span.badge.badge-success.badge-lg Completed
        - when 'failed'
          %span.badge.badge-error.badge-lg Failed

      .space-y-4
        .grid.grid-cols-2.gap-4
          %div
            %p.text-sm.font-semibold.opacity-60 YouTube URL
            %p= link_to @audio_extraction.youtube_url, @audio_extraction.youtube_url, target: '_blank', class: 'link link-primary break-all'
          %div
            %p.text-sm.font-semibold.opacity-60 Time Range
            - if @audio_extraction.start_time.present? || @audio_extraction.end_time.present?
              %p= [@audio_extraction.start_time, @audio_extraction.end_time].compact.join(' - ')
            - else
              %p.opacity-50 Full video

        - if @audio_extraction.in_progress?
          .alert.alert-info
            %span.loading.loading-spinner.loading-sm
            %span Extracting audio... This will update automatically when done.

        - if @audio_extraction.completed? && @audio_extraction.audio_file.attached?
          .divider
          .flex.items-center.gap-4
            = link_to rails_blob_path(@audio_extraction.audio_file, disposition: 'attachment'), class: 'btn btn-primary' do
              Download MP3
              - if @audio_extraction.file_size
                %span.badge.badge-ghost.ml-2= number_to_human_size(@audio_extraction.file_size)

        - if @audio_extraction.failed?
          .divider
          .alert.alert-error
            %div
              %p.font-semibold Error
              %p.text-sm= @audio_extraction.error_message
          .mt-4
            = link_to 'Try Again', new_admin_audio_extraction_path(youtube_url: @audio_extraction.youtube_url, start_time: @audio_extraction.start_time, end_time: @audio_extraction.end_time), class: 'btn btn-primary btn-sm'
