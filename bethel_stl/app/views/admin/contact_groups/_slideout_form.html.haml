- url = contact_group.persisted? ? admin_contact_group_path(contact_group, slideout: true) : admin_contact_groups_path(slideout: true)
- method = contact_group.persisted? ? :patch : :post

= form_with model: [:admin, contact_group], url: url, method: method do |f|
  - if contact_group.errors.any?
    .alert.alert-error.mb-6
      %ul
        - contact_group.errors.full_messages.each do |msg|
          %li= msg

  .form-control.mb-4
    %label.label
      %span.label-text Name
    = f.text_field :name, class: "input input-bordered w-full", required: true, placeholder: "e.g. Youth Group, Choir, Elders"

  .form-control.mb-6
    %label.label
      %span.label-text Members
    .bg-base-200.rounded-lg.p-4.max-h-72.overflow-y-auto
      - @members.each do |household, members|
        .mb-3
          %h4.font-semibold.text-sm.opacity-70.mb-1= household.name
          .ml-4.space-y-1
            - members.each do |member|
              %label.flex.items-center.gap-2.cursor-pointer
                = check_box_tag "contact_group[member_ids][]", member.id, contact_group.member_ids.include?(member.id), class: "checkbox checkbox-sm checkbox-primary"
                %span= member.full_name
                - if member.phone.present?
                  %span.text-xs.opacity-50= member.phone
                - else
                  %span.badge.badge-warning.badge-xs No phone

  = hidden_field_tag "contact_group[member_ids][]", ""

  .flex.items-center.gap-3
    .flex-1
    %button.btn.btn-ghost{ type: 'button', onclick: "this.closest('dialog').close()" } Cancel
    = f.submit (contact_group.persisted? ? 'Save Changes' : 'Create Group'), class: "btn btn-primary"
