- if contact_groups.any?
  .overflow-x-auto
    %table.table
      %thead
        %tr
          %th Name
          %th Members
          %th
      %tbody
        - contact_groups.each do |group|
          %tr.cursor-pointer.hover:bg-base-200{ data: { controller: 'modal', action: 'click->modal#open', modal_target_param: 'edit_contact_group_slideout', base_url: edit_admin_contact_group_path(group, slideout: true) } }
            %td.font-semibold= group.name
            %td
              .badge.badge-neutral= pluralize(group.members.count, "member")
            %td.text-right
              %button.btn.btn-xs.btn-ghost{ type: 'button', data: { controller: 'modal', action: 'click->modal#open', modal_target_param: 'edit_contact_group_slideout', base_url: edit_admin_contact_group_path(group, slideout: true) } } Edit
- else
  .text-center.py-6
    %p.opacity-60 No contact groups yet.
    %p.opacity-40.text-sm.mt-1 Groups let you send messages to specific sets of members.
