%h1.text-3xl.font-bold.mb-8 Messages

- if notice.present?
  .alert.alert-success.mb-6
    %span= notice

.flex.justify-end.mb-6
  = link_to "New Message", new_admin_message_path, class: "btn btn-primary"

.card.bg-base-100.shadow-md
  .card-body
    - if @messages.any?
      .overflow-x-auto
        %table.table
          %thead
            %tr
              %th Message
              %th Channel
              %th Recipients
              %th Schedule
              %th Status
              %th Sent / Failed
              %th
          %tbody
            - @messages.each do |message|
              %tr
                %td
                  = link_to admin_message_path(message), class: "link link-hover" do
                    = truncate(message.body, length: 60)
                %td
                  .badge.badge-outline.badge-sm= message.channel.upcase
                %td= message.recipient_label
                %td.whitespace-nowrap
                  - if message.scheduled_at.present?
                    = message.scheduled_at.strftime("%b %-d, %Y %-I:%M %p")
                  - else
                    %span.opacity-50 Immediate
                %td
                  - case message.status
                  - when "scheduled"
                    .badge.badge-info.badge-sm Scheduled
                  - when "sending"
                    .badge.badge-warning.badge-sm Sending
                  - when "sent"
                    .badge.badge-success.badge-sm Sent
                  - when "failed"
                    .badge.badge-error.badge-sm Failed
                %td
                  %span.text-success= message.sent_count
                  \/
                  %span.text-error= message.failed_count
                %td
                  = link_to "View", admin_message_path(message), class: "btn btn-sm btn-ghost"
    - else
      .text-center.py-8
        %p.text-lg.opacity-60 No messages yet.
        %p.opacity-40.mt-1 Send your first SMS message to church members.
