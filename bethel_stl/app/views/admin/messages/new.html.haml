%h1.text-3xl.font-bold.mb-8 New Message

.card.bg-base-100.shadow-md
  .card-body
    = form_with model: [:admin, @message], class: "space-y-6", data: { controller: "message-form" } do |f|
      - if @message.errors.any?
        .alert.alert-error.mb-4
          %ul
            - @message.errors.full_messages.each do |msg|
              %li= msg

      .form-control
        %label.label
          %span.label-text Recipients
        = f.select :contact_group_id, @contact_groups.map { |g| [g.name, g.id] }, { include_blank: "Everyone (all members with phone numbers)" }, class: "select select-bordered w-full"

      .form-control
        %label.label
          %span.label-text Message Body
        = f.text_area :body, class: "textarea textarea-bordered w-full h-32", required: true, placeholder: "Type your message here...", data: { controller: "character-count", character_count_target: "input" }
        .label
          %span.label-text-alt{ data: { character_count_target: "count" } }
            %span.opacity-60 SMS segments: 1 message = 160 characters. Longer messages use multiple segments.

      = f.hidden_field :channel, value: "sms"

      .form-control.max-w-xs
        %label.label
          %span.label-text Schedule (optional)
        = f.datetime_local_field :scheduled_at, class: "input input-bordered w-full", min: Time.current.strftime("%Y-%m-%dT%H:%M"), data: { message_form_target: "scheduledAt", action: "change->message-form#toggle" }
        .label
          %span.label-text-alt.opacity-60 Leave blank to send immediately.

      .flex.gap-3
        = f.submit "Send Now", class: "btn btn-primary", data: { message_form_target: "sendNowBtn", turbo_confirm: "Send this message to all recipients right now?" }
        = f.submit "Schedule", class: "btn btn-primary opacity-50", disabled: true, data: { message_form_target: "scheduleBtn" }
        = link_to "Cancel", admin_messages_path, class: "btn btn-ghost"
