%h1.text-3xl.font-bold.mb-8 Message Details

= link_to "← Back to Messages", admin_messages_path, class: "btn btn-ghost btn-sm mb-6"

.card.bg-base-100.shadow-md.mb-8
  .card-body
    .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-6
      %div
        %h3.font-semibold.text-sm.opacity-60 Recipients
        %p= @message.recipient_label
      %div
        %h3.font-semibold.text-sm.opacity-60 Channel
        .badge.badge-outline= @message.channel.upcase
      %div
        %h3.font-semibold.text-sm.opacity-60 Status
        - case @message.status
        - when "scheduled"
          .badge.badge-info Scheduled
        - when "sending"
          .badge.badge-warning Sending
        - when "sent"
          .badge.badge-success Sent
        - when "failed"
          .badge.badge-error Failed
      %div
        %h3.font-semibold.text-sm.opacity-60 Scheduled At
        - if @message.scheduled_at.present?
          %p= @message.scheduled_at.strftime("%b %-d, %Y %-I:%M %p")
        - else
          %p.opacity-50 Immediate
      %div
        %h3.font-semibold.text-sm.opacity-60 Sent At
        %p= @message.sent_at&.strftime("%b %-d, %Y %-I:%M %p") || "—"
      %div
        %h3.font-semibold.text-sm.opacity-60 Results
        %p
          %span.text-success= @message.sent_count
          sent,
          %span.text-error= @message.failed_count
          failed

    .divider

    %h3.font-semibold.mb-2 Message Body
    .bg-base-200.rounded-lg.p-4.whitespace-pre-wrap= @message.body

-# ==================== DELIVERY LOG ====================
.card.bg-base-100.shadow-md
  .card-body
    %h2.card-title.mb-4 Delivery Log

    - if @deliveries.any?
      .overflow-x-auto
        %table.table
          %thead
            %tr
              %th Member
              %th Phone
              %th Status
              %th Error
              %th Delivered At
          %tbody
            - @deliveries.each do |delivery|
              %tr
                %td= delivery.member.full_name
                %td= delivery.phone_or_email
                %td
                  - case delivery.status
                  - when "pending"
                    .badge.badge-ghost.badge-sm Pending
                  - when "sent"
                    .badge.badge-success.badge-sm Sent
                  - when "failed"
                    .badge.badge-error.badge-sm Failed
                %td
                  - if delivery.error_message.present?
                    %span.text-error.text-sm= delivery.error_message
                  - else
                    %span.opacity-30 —
                %td= delivery.delivered_at&.strftime("%b %-d %-I:%M %p") || "—"
    - else
      .text-center.py-8
        %p.opacity-60
          - if @message.scheduled?
            Message hasn't been sent yet.
          - elsif @message.sending?
            Message is being sent...
          - else
            No delivery records.
