.flex.justify-between.items-center.mb-8
  %h1.text-3xl.font-bold Directory
  %button.btn.btn-primary{ type: 'button', data: { controller: 'modal', action: 'click->modal#open', modal_target_param: 'add_household_slideout' } }
    + New Household

#households_table
  = render 'admin/households/households_table', households: @households

-# New Household slideout
= render 'admin/shared/slideout', id: 'add_household_slideout',
    title: 'New Household', size: :lg,
    turbo_frame: 'add_household_form',
    turbo_src: new_admin_household_path(slideout: true)

-# View Household slideout (src set dynamically per row)
= render 'admin/shared/slideout', id: 'view_household_slideout',
    title: 'Household Details', size: :md,
    turbo_frame: 'view_household_content',
    turbo_src: '#'

-# Edit Household slideout (src set dynamically per row via data-base-url)
= render 'admin/shared/slideout', id: 'edit_household_slideout',
    title: 'Edit Household', size: :lg,
    turbo_frame: 'edit_household_form',
    turbo_src: '#'
