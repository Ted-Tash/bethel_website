.flex.justify-between.items-center.mb-8
  %h1.text-3xl.font-bold= @household.name
  .flex.gap-2
    = link_to 'Edit', edit_admin_household_path(@household), class: 'btn btn-outline btn-sm'
    = button_to 'Delete', admin_household_path(@household), method: :delete, class: 'btn btn-secondary btn-sm', data: { turbo_confirm: 'Are you sure you want to delete this household?' }

.grid.grid-cols-1.lg:grid-cols-2.gap-6
  .card.bg-base-100.shadow-md
    .card-body
      %h2.card-title Members
      - @household.members.each do |member|
        .py-3.border-b.last:border-b-0
          %p.font-semibold= member.full_name
          - if member.email.present?
            %p.text-sm.opacity-70= member.email
          - if member.phone.present?
            %p.text-sm.opacity-70= member.phone

  .card.bg-base-100.shadow-md
    .card-body
      %h2.card-title Address
      - if @household.full_address.present?
        %p= @household.street
        %p
          = @household.city
          - if @household.state.present?
            = ", #{@household.state}"
          - if @household.zip.present?
            = " #{@household.zip}"
      - else
        %p.opacity-60 No address on file

.mt-6
  = link_to '← Back to Directory', admin_households_path, class: 'btn btn-ghost btn-sm'
