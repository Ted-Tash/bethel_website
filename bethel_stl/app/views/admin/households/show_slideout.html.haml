%turbo-frame#view_household_content
  .space-y-6
    -# Members
    %div
      %h3.font-medium.text-base.mb-3 Members
      - @household.members.each do |member|
        .py-3.border-b.last:border-b-0
          %p.font-semibold= member.full_name
          - if member.email.present?
            %p.text-sm.opacity-70= member.email
          - if member.phone.present?
            %p.text-sm.opacity-70= member.phone

    -# Address
    %div
      %h3.font-medium.text-base.mb-3 Address
      - if @household.full_address.present?
        %p= @household.street
        %p
          = @household.city
          - if @household.state.present?
            = ", #{@household.state}"
          - if @household.zip.present?
            = " #{@household.zip}"
      - else
        %p.opacity-60 No address on file

    -# Actions
    .flex.items-center.gap-3.border-t.border-base-300.pt-4.mt-4
      %button.btn.btn-ghost{ type: 'button', data: { controller: 'modal', action: 'click->modal#open', modal_target_param: 'edit_household_slideout', base_url: edit_admin_household_path(@household, slideout: true) }, onclick: "this.closest('dialog').close()" } Edit
      .flex-1
      = button_to admin_household_path(@household), method: :delete, class: 'btn btn-ghost', style: 'color: red;', data: { turbo_confirm: 'Are you sure you want to delete this household and all its members?', turbo_frame: '_top' } do
        %svg.w-6.h-6{ xmlns: "http://www.w3.org/2000/svg", fill: "none", viewBox: "0 0 24 24", "stroke-width" => "1.5", stroke: "red" }
          %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", d: "m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" }
