%turbo-frame#edit_document_form
  = form_with model: [:admin, @recording, @document], url: admin_recording_document_path(@recording, @document, slideout: true), method: :patch do |f|
    - if @document.errors.any?
      .alert.alert-error.mb-6
        %ul
          - @document.errors.full_messages.each do |message|
            %li= message

    .space-y-4.mb-6
      .form-control
        %label.label
          %span.label-text Name
        = f.text_field :name, class: 'input input-bordered w-full', placeholder: 'Optional display name'

      %div
        %p.text-sm.opacity-60 File
        .flex.items-center.gap-2.mt-1
          %svg.w-5.h-5.opacity-60{ xmlns: "http://www.w3.org/2000/svg", fill: "none", viewBox: "0 0 24 24", "stroke-width" => "1.5", stroke: "currentColor" }
            %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", d: "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" }
          = link_to @document.file.filename, rails_blob_path(@document.file, disposition: :inline), target: '_blank', class: 'link link-primary text-sm'
        .text-xs.opacity-50.mt-1
          = number_to_human_size(@document.file.byte_size)
          \·
          = @document.file.content_type

    .flex.items-center.gap-3
      .flex-1
      %button.btn.btn-ghost{ type: 'button', onclick: "this.closest('dialog').close()" } Cancel
      = f.submit 'Save', class: 'btn btn-primary'
