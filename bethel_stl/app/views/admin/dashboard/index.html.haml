%h1.text-3xl.font-bold.mb-8 Dashboard

.grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-3.gap-6
  = link_to admin_recordings_path, class: 'card bg-base-100 shadow-md hover:shadow-lg transition-shadow' do
    .card-body
      %h2.card-title Sermons
      %p.opacity-60 Manage sermon recordings and archives
      .card-actions.justify-end
        .badge.badge-primary= "#{Recording.count} Sermons"

  = link_to admin_events_path, class: 'card bg-base-100 shadow-md hover:shadow-lg transition-shadow' do
    .card-body
      %h2.card-title Events
      %p.opacity-60 Manage upcoming church events
      .card-actions.justify-end
        .badge.badge-primary= "#{Event.upcoming.count} Upcoming"

  = link_to admin_households_path, class: 'card bg-base-100 shadow-md hover:shadow-lg transition-shadow' do
    .card-body
      %h2.card-title Directory
      %p.opacity-60 Manage church household contacts
      .card-actions.justify-end
        .badge.badge-primary= "#{Household.count} Households"

  = link_to admin_messages_path, class: 'card bg-base-100 shadow-md hover:shadow-lg transition-shadow' do
    .card-body
      %h2.card-title Messages
      %p.opacity-60 Send SMS messages to church members
      .card-actions.justify-end
        .badge.badge-primary= "#{Message.count} Messages"

  = link_to admin_audio_extractions_path, class: 'card bg-base-100 shadow-md hover:shadow-lg transition-shadow' do
    .card-body
      %h2.card-title Audio Extractor
      %p.opacity-60 Extract MP3 audio from YouTube streams
      .card-actions.justify-end
        .badge.badge-primary= "#{AudioExtraction.count} Extractions"
